# Copy this file to `.env.local` and fill in your key.
#
# Get a key from https://console.anthropic.com/ (Settings -> API Keys).
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the model used for extraction.
# Defaults to claude-opus-4-8 (strong vision + native PDF understanding).
# claude-sonnet-5 is a faster / cheaper alternative that also works well.
# ANTHROPIC_MODEL=claude-opus-4-8

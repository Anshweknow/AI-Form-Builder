# Copy this file to `.env.local` and fill in your key.
#
# Get a key from Google AI Studio: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key

# Optional: override the model used for extraction.
# Defaults to gemini-2.5-flash (fast, multimodal, native PDF + image understanding).
# gemini-2.5-pro is a higher-accuracy alternative.
# GEMINI_MODEL=gemini-2.5-flash
